:"code","lang":"python","executable":true,"value":"%%time\nkerchunk_url = \"https://data.gdex.ucar.edu/d559000/kerchunk/wrf2d-remote-https.parq\"\n\nds = xr.open_dataset(kerchunk_url, engine=\"kerchunk\", \\\n                     storage_options={\"remote_protocol\": \"https\"})\npr = ds[\"PREC_ACC_NC\"]\nlat2d = ds[\"XLAT\"].isel(Time=0)\nlon2d = ds[\"XLONG\"].isel(Time=0)\npr","key":"wpaXtw7bmB"},{"type":"outputs","id":"rtpvpHus8WpKFTBXET5VX","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 7.47 s, sys: 1.94 s, total: 9.41 s\nWall time: 4min 8s\n"},"key":"ZtIXBckwmr"},{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m--------------------------------------------------------...","ename":"FSTimeoutError","evalue":"","hash":"e026b9016a730c2279572a55dea366e3","path":"/gdex-cookbook/build/e026b9016a730c2279572a55dea366e3.txt"},"key":"ezQQVyQGWs"}],"key":"QDasffyXJK"}],"key":"XVEUOZGMmV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nmonth = \"2017-02\"\npr_month = pr.sel(Time=month).sum(\"Time\").compute()","key":"ojv8Zi3aKj"},{"type":"outputs","id":"XB0wMDKnGer2pKeYqKIt2","children":[],"key":"hDpA4pXRQ9"}],"key":"oETExnbvpc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Mapping the monthly total","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HTDtsSoanL"}],"identifier":"mapping-the-monthly-total","label":"Mapping the monthly total","html_id":"mapping-the-monthly-total","implicit":true,"key":"auqjLKJk05"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"CONUS404 sits on a Lambert Conformal grid. We coarsen 4× for plotting (to spare\nCartopy memory) and use the NCL ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"TODBckxUwH"},{"type":"inlineCode","value":"precip3_16lev","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kATNW10lcQ"},{"type":"text","value":" palette.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UJShhsojzS"}],"key":"bcGWoZxMKA"}],"key":"JV3FlK0XRQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"proj = ccrs.LambertConformal(central_longitude=-97.5, central_latitude=38.5)\ntrans = ccrs.PlateCarree()\n\n_rgb255 = [\n    (255, 255, 255), (214, 226, 255), (181, 201, 255), (142, 178, 255),\n    (127, 150, 255), (114, 133, 248), (99, 112, 248), (0, 158, 30),\n    (60, 188, 61), (179, 209, 110), (185, 249, 110), (255, 249, 19),\n    (255, 163, 9), (229, 0, 0), (189, 0, 31), (165, 0, 33),\n]\ncmap_pr = ListedColormap(np.array(_rgb255) / 255, name=\"precip3_16lev\")\nlevels = np.arange(0, 301, 20)\nnorm = BoundaryNorm(levels, ncolors=cmap_pr.N, extend=\"max\")\n\nkw = dict(south_north=4, west_east=4, boundary=\"trim\")\npr_plot = pr_month.coarsen(**kw).mean()\nlat_plot = lat2d.coarsen(**kw).mean()\nlon_plot = lon2d.coarsen(**kw).mean()\n\nfig, ax = plt.subplots(figsize=(11, 7), subplot_kw={\"projection\": proj})\nim = ax.pcolormesh(\n    lon_plot.values, lat_plot.values, pr_plot.values,\n    transform=trans, cmap=cmap_pr, norm=norm, shading=\"auto\",\n)\nax.add_feature(cfeature.COASTLINE, lw=0.4)\nax.add_feature(cfeature.BORDERS, lw=0.4)\nax.add_feature(cfeature.STATES, lw=0.2)\nax.set_extent([-125, -66, 24, 50], crs=trans)\n\nfig.colorbar(im, ax=ax, shrink=0.7, ticks=levels, extend=\"max\",\n             label=\"Monthly precipitation (mm)\")\nax.set_title(\"CONUS404 total precipitation — February 2017\")\nplt.show()","key":"PVSUCmAyX6"},{"type":"outputs","id":"lZKLmrX7Pjj1pIB4AmZZQ","children":[],"key":"psjAFNzlmJ"}],"key":"WyUWJgX9mZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"Rjqfw04NjK"},{"type":"outputs","id":"aBBenL6Rke_PZTRGy4G8x","children":[],"key":"XMlEr9xPav"}],"key":"kHMAyulREd"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z7qVcp1xMr"}],"key":"iWaeil6dyI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sIo5e9l3Z2"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"NL1K8PWS5H"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"We opened CONUS404’s 2D output from a single kerchunk reference over OSDF, summed\none month of hourly precipitation, and mapped the total across CONUS on the model’s\nnative Lambert Conformal grid. Scoping to one month keeps the stream small — loop\nthe reduction over months or water years to rebuild the published multi-year\nclimatology.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Esy1ewgDph"}],"key":"d2uEjvPoGr"}],"key":"hFmPNZmVSU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Resources and references","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SsIZy4UNTe"}],"identifier":"resources-and-references","label":"Resources and references","html_id":"resources-and-references","implicit":true,"key":"mSv0xs5J4a"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":7,"co