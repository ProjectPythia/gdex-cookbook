column":1},"end":{"line":3,"column":1}},"key":"pg9jKWD78W"},{"type":"inlineCode","value":"R²","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"OFxBoERILG"},{"type":"text","value":" quantify it.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"CGx5r97ii7"}],"key":"c1jDNfpsDd"}],"key":"YgA6jsepnV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"u_wind\", \"v_wind\", \"w_wind\"]\nfig, axes = plt.subplots(1, 3, figsize=(18, 6))\n\nfor ax, var in zip(axes, vars_to_compare):\n    x = prof449[var].values.ravel()\n    y = era5[var].values.ravel()\n    mask = ~np.isnan(x) & ~np.isnan(y)\n    x, y = x[mask], y[mask]\n\n    ax.scatter(x, y, s=5, alpha=0.5)\n    lims = [min(x.min(), y.min()), max(x.max(), y.max())]\n    ax.plot(lims, lims, \"r--\", label=\"x = y\")\n\n    r = np.corrcoef(x, y)[0, 1]\n    ax.text(0.05, 0.95, f\"r = {r:.2f}\\nR² = {r**2:.2f}\", transform=ax.transAxes,\n            va=\"top\", ha=\"left\", bbox=dict(boxstyle=\"round\", facecolor=\"white\", alpha=0.7))\n    ax.set_xlabel(f\"449 MHz profiler {var}\")\n    ax.set_ylabel(f\"ERA5 {var}\")\n    ax.set_title(f\"Comparison of {var}\")\n    ax.legend()\n\nplt.tight_layout()\nplt.show()","key":"uyJUi48091"},{"type":"outputs","id":"XkvYSWAGlBjkG5MVYwzzf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m--------------------------------------------------------...","ename":"ClientResponseError","evalue":"500, message='Internal Server Error', url='https://dtn-pas.bois.nrp.internet2.edu:8443/ncar/gdex/d121499/era5_M2HATS_heights.zarr/u_wind/c/1279/0'","hash":"5121b01ad402b3381e4b0cd1d9ab63dc","path":"/gdex-cookbook/build/5121b01ad402b3381e4b0cd1d9ab63dc.txt"},"key":"FfxmHUNKDl"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1800x600 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a308f9d916d70d6578407fc9170757aa","path":"/gdex-cookbook/build/a308f9d916d70d6578407fc9170757aa.png"}}},"key":"c4dTYfCxSd"}],"key":"B8mhR2tfe2"}],"key":"r40XRQYeYX"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The horizontal components (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"J7yVc1OVoX"},{"type":"inlineCode","value":"u_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"In3LkacdLa"},{"type":"text","value":", ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zTGrb8rknk"},{"type":"inlineCode","value":"v_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"B4BsknQZqb"},{"type":"text","value":") track the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tFDGU5hWWI"},{"type":"inlineCode","value":"x = y","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HHCKP8pRFJ"},{"type":"text","value":" line closely with\nhigh ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QP2N8OxfTc"},{"type":"inlineCode","value":"R²","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"opsaMii4F0"},{"type":"text","value":" — ERA5 represents them well. The vertical wind (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WMz5onjodS"},{"type":"inlineCode","value":"w_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xIi75wSV1V"},{"type":"text","value":") scatters far more,\na known limitation of reanalysis for small-scale vertical motion.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SGe7vKYUrY"}],"key":"qFKwDdGGjU"}],"key":"GgB6SXZP5F"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Attributing the differences","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uvDWwmlSZp"}],"identifier":"attributing-the-differences","label":"Attributing the differences","html_id":"attributing-the-differences","implicit":true,"key":"Uc4CN0TTt4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Where do the two diverge? We break the mean absolute error (MAE) down by day, hour\nof day, and height — for wind speed, direction, and vertical wind. Wind direction\nuses a circular difference so the 0°/360° wrap doesn’t inflate the error.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vqDtzP7zML"}],"key":"z3W2MlgYFj"}],"key":"AGHhSlDbDC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"wspd\", \"wdir\", \"w_wind\"]\nfig, axes = plt.subplots(nrows=3, ncols=3, figsize=(18, 14))\n\nfor row, var in enumerate(vars_to_compare):\n    obs = prof449[var].values\n    mod = era5[var].values\n    time = prof449[\"time\"].values\n    height = prof449[\"height_msl\"].values\n\n    if var == \"wdir\":\n        error = np.abs((obs - mod + 180) % 360 - 180)\n    else:\n        error = np.abs(obs - mod)\n\n    df = pd.DataFrame({\n        \"time\": np.repeat(time, len(height)),\n        \"error\": error.reshape(len(time) * len(height)),\n    })\n    df[\"day\"] = pd.to_datetime(df[\"time\"]).dt.date\n    df[\"hour\"] = pd.to_datetime(df[\"time\"]).dt.hour\n    mae_daily = df.groupby(\"day\")[\"error\"].mean()\n    mae_hourly = df.groupby(\"hour\")[\"error\"].mean()\n    mae_height = np.nanmean(error, axis=0)\n\n    axes[row, 0].plot(mae_daily.index, mae_daily.values, marker=\"o\")\n    axes[row, 0].set_title(f\"{var}: MAE by day\")\n    axes[row, 0].set_ylabel(\"MAE\")\n    axes[row, 0].tick_params(axis=\"x\", rotation=45)\n\n    axes[row, 1].plot(mae_hourly.index, mae_hourly.values, marker=\"o\")\n    axes[row, 1].set_title(f\"{var}: MAE by hour of day\")\n    axes[row, 1].set_xlabel(\"Hour (UTC)\")\n\n    axes[row, 2].plot(mae_height, height)\n    axes[row, 2].set_title(f\"{var}: MAE by height\")\n    axes[row, 2].set_xlabel(\"MAE\")\n    axes[row, 2].set_ylabel(\"Height (m MSL)\")\n\nplt.tight_layout()\nplt.show()","key":"H8zCwr2BTS"},{"type":"outputs","id":"zoXBuOmAae7WVZkLBoFzq","children":[],"key":"OgwCb6L45L"}],"key":"Eux4YJZoaF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"The breakdown localizes the disagreement: wind-speed MAE spikes on 20–21 Aug 2023,\ncoinciding with the passage of Tropical Storm Hilary; there’s a diurnal signal by\nhour; and error grows with height. This is exactly the payoff of fusing the two\ndatasets — the comparison points to ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ffN65lM8cg"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"when","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qephIRmGJr"}],"key":"KMppTtINI2"},{"type":"text","value":" and ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XS5RTZFnLs"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"where","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bX5K8Yx24n"}],"key":"AeEd33jGOD"},{"type":"text","value":" to look closer.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jrq4IFD2X5"}],"key":"LYBaJYvP1J"}],"key":"Jr2RtAzqsH"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Cr1Zk4piwb"}],"key":"ITjmHy6QMS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gbsZXOHOr6"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"jklpnYvJrz"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"We fused two GDEX datasets — 449 MHz profiler observations and ERA5 reanalysis —\nfrom a single campaign dataset, aligned them onto a common time/height grid, and\ncompared wind components with scatter plots and an MAE breakdown by day, hour, and\nheight. The same recipe (open → align → compare → attribute) generalizes to any\nobs-vs-model or model-vs-model comparison on GDEX.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"BHhBs9wDfh"}],"key":"WWNTd9ukFl"},{"type":"heading","depth":3,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Wj0ZQrgx2K"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"VkXlxgMkkJ"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"This rounds out the workflow series. Feel free to open a pull request and contribute a new workflow!","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"daz4TB2HMw"}],"key":"PGLA7ybh4s"}],"key":"ZNjQsCHCjL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth