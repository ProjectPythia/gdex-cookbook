ebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"u_wind\", \"v_wind\", \"w_wind\"]\nfig, axes = plt.subplots(1, 3, figsize=(18, 6))\n\nfor ax, var in zip(axes, vars_to_compare):\n    x = prof449[var].values.ravel()\n    y = era5[var].values.ravel()\n    mask = ~np.isnan(x) & ~np.isnan(y)\n    x, y = x[mask], y[mask]\n\n    ax.scatter(x, y, s=5, alpha=0.5)\n    lims = [min(x.min(), y.min()), max(x.max(), y.max())]\n    ax.plot(lims, lims, \"r--\", label=\"x = y\")\n\n    r = np.corrcoef(x, y)[0, 1]\n    ax.text(0.05, 0.95, f\"r = {r:.2f}\\nR² = {r**2:.2f}\", transform=ax.transAxes,\n            va=\"top\", ha=\"left\", bbox=dict(boxstyle=\"round\", facecolor=\"white\", alpha=0.7))\n    ax.set_xlabel(f\"449 MHz profiler {var}\")\n    ax.set_ylabel(f\"ERA5 {var}\")\n    ax.set_title(f\"Comparison of {var}\")\n    ax.legend()\n\nplt.tight_layout()\nplt.show()","key":"m4jX56T8ky"},{"type":"outputs","id":"zAfzULxGXXkBSRHnaQvzA","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1800x600 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"627a29f682d303a9fc5bc1e47f081357","path":"/gdex-cookbook/build/627a29f682d303a9fc5bc1e47f081357.png"}}},"key":"Hhk7R4PtWT"}],"key":"fTLtKqcjG1"}],"key":"aldKslyxRT"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The horizontal components (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PTwpHjKre8"},{"type":"inlineCode","value":"u_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CWDUhZZUpy"},{"type":"text","value":", ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KRq0HQdhXi"},{"type":"inlineCode","value":"v_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VohMYHuMZq"},{"type":"text","value":") track the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cyynWQSuxo"},{"type":"inlineCode","value":"x = y","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Wmu44UaECm"},{"type":"text","value":" line closely with\nhigh ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qbWyhlzFE9"},{"type":"inlineCode","value":"R²","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Cs6ounesgO"},{"type":"text","value":" — ERA5 represents them well. The vertical wind (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DpQChVeHys"},{"type":"inlineCode","value":"w_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KlaI5FHNrh"},{"type":"text","value":") scatters far more,\na known limitation of reanalysis for small-scale vertical motion.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EGnxwhfLCS"}],"key":"YOO0Ky1WgM"}],"key":"JYSvQDHbzB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Attributing the differences","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"UQKz7bUAce"}],"identifier":"attributing-the-differences","label":"Attributing the differences","html_id":"attributing-the-differences","implicit":true,"key":"pQgYc9crvs"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Where do the two diverge? We break the mean absolute error (MAE) down by day, hour\nof day, and height — for wind speed, direction, and vertical wind. Wind direction\nuses a circular difference so the 0°/360° wrap doesn’t inflate the error.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"L7ckMxYvlX"}],"key":"KgyfeVV9R4"}],"key":"V9tUPcKRrU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"wspd\", \"wdir\", \"w_wind\"]\nfig, axes = plt.subplots(nrows=3, ncols=3, figsize=(18, 14))\n\nfor row, var in enumerate(vars_to_compare):\n    obs = prof449[var].values\n    mod = era5[var].values\n    time = prof449[\"time\"].values\n    height = prof449[\"height_msl\"].values\n\n    if var == \"wdir\":\n        error = np.abs((obs - mod + 180) % 360 - 180)\n    else:\n        error = np.abs(obs - mod)\n\n    df = pd.DataFrame({\n        \"time\": np.repeat(time, len(height)),\n        \"error\": error.reshape(len(time) * len(height)),\n    })\n    df[\"day\"] = pd.to_datetime(df[\"time\"]).dt.date\n    df[\"hour\"] = pd.to_datetime(df[\"time\"]).dt.hour\n    mae_daily = df.groupby(\"day\")[\"error\"].mean()\n    mae_hourly = df.groupby(\"hour\")[\"error\"].mean()\n    mae_height = np.nanmean(error, axis=0)\n\n    axes[row, 0].plot(mae_daily.index, mae_daily.values, marker=\"o\")\n    axes[row, 0].set_title(f\"{var}: MAE by day\")\n    axes[row, 0].set_ylabel(\"MAE\")\n    axes[row, 0].tick_params(axis=\"x\", rotation=45)\n\n    axes[row, 1].plot(mae_hourly.index, mae_hourly.values, marker=\"o\")\n    axes[row, 1].set_title(f\"{var}: MAE by hour of day\")\n    axes[row, 1].set_xlabel(\"Hour (UTC)\")\n\n    axes[row, 2].plot(mae_height, height)\n    axes[row, 2].set_title(f\"{var}: MAE by height\")\n    axes[row, 2].set_xlabel(\"MAE\")\n    axes[row, 2].set_ylabel(\"Height (m MSL)\")\n\nplt.tight_layout()\nplt.show()","key":"b18W36X7C9"},{"type":"outputs","id":"Nicchw7L1G6Axe6wsDwcL","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_5015/396819726.py:23: RuntimeWarning: Mean of empty slice\n  mae_height = np.nanmean(error, axis=0)\n"},"key":"QDweN5vo6h"}