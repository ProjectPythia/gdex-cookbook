":"fz2tdzjqrj"}],"key":"EiiB29UL7a"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Aligning the datasets","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kULVjKxqCq"}],"identifier":"aligning-the-datasets","label":"Aligning the datasets","html_id":"aligning-the-datasets","implicit":true,"key":"di59dcOSQS"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"The profiler reports every 30 minutes while ERA5 is hourly. Interpolating the\nprofiler onto the ERA5 time grid puts both on identical time and height coordinates\n— the step that makes a point-by-point comparison meaningful.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yjUTcaVIr7"}],"key":"OKNgHTfeFs"}],"key":"ttC2t1Bdnm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"prof449 = prof449.interp(time=era5[\"time\"])","key":"YdNkNuDMWC"},{"type":"outputs","id":"HNQIc8_BoHdOCUmtBn8qV","children":[],"key":"uKnWusLrYv"}],"key":"ja3svyHjCg"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Comparing wind components","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oS1LCNuuuZ"}],"identifier":"comparing-wind-components","label":"Comparing wind components","html_id":"comparing-wind-components","implicit":true,"key":"ohJf9leKGY"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"We scatter each profiler wind component against ERA5 over the whole campaign. Points\nnear the ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"