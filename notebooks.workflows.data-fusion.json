ebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"u_wind\", \"v_wind\", \"w_wind\"]\nfig, axes = plt.subplots(1, 3, figsize=(18, 6))\n\nfor ax, var in zip(axes, vars_to_compare):\n    x = prof449[var].values.ravel()\n    y = era5[var].values.ravel()\n    mask = ~np.isnan(x) & ~np.isnan(y)\n    x, y = x[mask], y[mask]\n\n    ax.scatter(x, y, s=5, alpha=0.5)\n    lims = [min(x.min(), y.min()), max(x.max(), y.max())]\n    ax.plot(lims, lims, \"r--\", label=\"x = y\")\n\n    r = np.corrcoef(x, y)[0, 1]\n    ax.text(0.05, 0.95, f\"r = {r:.2f}\\nR² = {r**2:.2f}\", transform=ax.transAxes,\n            va=\"top\", ha=\"left\", bbox=dict(boxstyle=\"round\", facecolor=\"white\", alpha=0.7))\n    ax.set_xlabel(f\"449 MHz profiler {var}\")\n    ax.set_ylabel(f\"ERA5 {var}\")\n    ax.set_title(f\"Comparison of {var}\")\n    ax.legend()\n\nplt.tight_layout()\nplt.show()","key":"tkh4VCPc5H"},{"type":"outputs","id":"xD_C15hwRe10DaREM-DWi","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m--------------------------------------------------------...","ename":"ClientResponseError","evalue":"500, message='Internal Server Error', url='https://osg-houston-stashcache.nrp.internet2.edu:8443/ncar/gdex/d121499/prof449_M2HATS_winds30.zarr/u_wind/c/26/0'","hash":"b920b47da8f00e1887e1a9a0d73eadfe","path":"/gdex-cookbook/build/b920b47da8f00e1887e1a9a0d73eadfe.txt"},"key":"ClyHTIQlqY"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1800x600 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a308f9d916d70d6578407fc9170757aa","path":"/gdex-cookbook/build/a308f9d916d70d6578407fc9170757aa.png"}}},"key":"QWFrzMAzuX"}],"key":"iIbWWNJ9IV"}],"key":"DHM9oc5KdE"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The horizontal components (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qvWNxGmkRT"},{"type":"inlineCode","value":"u_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zaJCx5Zowd"},{"type":"text","value":", ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JzUFPrFpyU"},{"type":"inlineCode","value":"v_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"iezddbHrJb"},{"type":"text","value":") track the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hTC6FxnZme"},{"type":"inlineCode","value":"x = y","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ry3gNzHqPy"},{"type":"text","value":" line closely with\nhigh ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"R7CFwPWf90"},{"type":"inlineCode","value":"R²","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Q8RbLfJv0y"},{"type":"text","value":" — ERA5 represents them well. The vertical wind (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GUkqvC3e8K"},{"type":"inlineCode","value":"w_wind","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Q73zPmsdPM"},{"type":"text","value":") scatters far more,\na known limitation of reanalysis for small-scale vertical motion.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IIWSZvdBl0"}],"key":"WhndZHOAWT"}],"key":"sanFkPl3Ap"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Attributing the differences","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rBD40OqoDs"}],"identifier":"attributing-the-differences","label":"Attributing the differences","html_id":"attributing-the-differences","implicit":true,"key":"cNw6Nu48AC"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Where do the two diverge? We break the mean absolute error (MAE) down by day, hour\nof day, and height — for wind speed, direction, and vertical wind. Wind direction\nuses a circular difference so the 0°/360° wrap doesn’t inflate the error.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wLjmDOLvJ5"}],"key":"PiLMXDMmFv"}],"key":"al6eqnabFV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"vars_to_compare = [\"wspd\", \"wdir\", \"w_wind\"]\nfig, axes = plt.subplots(nrows=3, ncols=3, figsize=(18, 14))\n\nfor row, var in enumerate(vars_to_compare):\n    obs = prof449[var].values\n    mod = era5[var].values\n    time = prof449[\"time\"].values\n    height = prof449[\"height_msl\"].values\n\n    if var == \"wdir\":\n        error = np.abs((obs - mod + 180) % 360 - 180)\n    else:\n        error = np.abs(obs - mod)\n\n    df = pd.DataFrame({\n        \"time\": np.repeat(time, len(height)),\n        \"error\": error.reshape(len(time) * len(height)),\n    })\n    df[\"day\"] = pd.to_datetime(df[\"time\"]).dt.date\n    df[\"hour\"] = pd.to_datetime(df[\"time\"]).dt.hour\n    mae_daily = df.groupby(\"day\")[\"error\"].mean()\n    mae_hourly = df.groupby(\"hour\")[\"error\"].mean()\n    mae_height = np.nanmean(error, axis=0)\n\n    axes[row, 0].plot(mae_daily.index, mae_daily.values, marker=\"o\")\n    axes[row, 0].set_title(f\"{var}: MAE by day\")\n    axes[row, 0].set_ylabel(\"MAE\")\n    axes[row, 0].tick_params(axis=\"x\", rotation=45)\n\n    axes[row, 1].plot(mae_hourly.index, mae_hourly.values, marker=\"o\")\n    axes[row, 1].set_title(f\"{var}: MAE by hour of day\")\n    axes[row, 1].set_xlabel(\"Hour (UTC)\")\n\n    axes[row, 2].plot(mae_height, height)\n    axes[row, 2].set_title(f\"{var}: MAE by height\")\n    axes[row, 2].set_xlabel(\"MAE\")\n    axes[row, 2].set_ylabel(\"Height (m MSL)\")\n\nplt.tight_layout()\nplt.show()","key":"hQJXtw7v1P"},{"type":"outputs","id":"yXey7XSczGFxchSDq6WB5","children":[],"key":"dSh8vzYRIg"}],"key":"Vgdt446239"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"The breakdown localizes the disagreement: wind-speed MAE spikes on 20–21 Aug 2023,\ncoinciding with the passage of Tropical Storm Hilary; there’s a diurnal signal by\nhour; and error grows with height. This is exactly the payoff of fusing the two\ndatasets — the comparison points to ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"FmDZIueglx"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"when","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AsLpqSJrCH"}],"key":"bQSKumIuBs"},{"type":"text","value":" and ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sjrFYRfd8G"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"where","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Y0FhO1DtPI"}],"key":"kow47q64fB"},{"type":"text","value":" to look closer.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vFqp2Ln8xo"}],"key":"ymjmcX7wsn"}],"key":"NikNYFahWw"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZHNEFUIFqG"}],"key":"GgGNW5gKTe"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ctsGGebQMF"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"JTduLhkqQW"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"We fused two GDEX datasets — 449 MHz profiler observations and ERA5 reanalysis —\nfrom a single campaign dataset, aligned them onto a common time/height grid, and\ncompared wind components with scatter plots and an MAE breakdown by day, hour, and\nheight. The same recipe (open → align → compare → attribute) generalizes to any\nobs-vs-model or model-vs-model comparison on GDEX.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"cW4bPo1GCo"}],"key":"pJGIAZfYqw"},{"type":"heading","depth":3,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"DEGeWaBSBJ"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"YgktIwaspF"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"This rounds out the workflow series. Feel free to open a pull request and contribute a new workflow!","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"oVwyAYvmKM"}],"key":"JKn56rT2va"}],"key":"tApn1KhH9B"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Resources and references","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"k5XdYyItYN"}],"identifier":"resources-and-references","label":"Resources and references","html_id":"resources-and-references","implicit":true,"key":"oJqkpzvIg