art":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"NSF NCAR’s Geoscience Data Exchange (GDEX) hosts thousands of freely accessible geoscience datasets — from global reanalyses like ERA5 and JRA-3Q to climate model output and observational records — but knowing how to find, access, and work with that data can be a significant barrier for new users. This cookbook removes that barrier. By the end, you will know how to discover datasets on GDEX, choose the right access method for your workflow (bulk download, THREDDS/OPeNDAP streaming, Zarr cloud access, Globus, or the REST API), and apply those skills to real datasets across a range of geoscience workflows. You will also learn how to submit your own data to GDEX for long-term stewardship and citation.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"pV0y2Q2kK7"}],"key":"lBDkaEYjUO"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Authors","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"AHU5A0OkfE"}],"identifier":"authors","label":"Authors","html_id":"authors","implicit":true,"key":"rVCn6Rnexh"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"link","url":"https://github.com/hrhampapura","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Harsha R. Hampapura","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"eqEDGjm47l"}],"urlSource":"https://github.com/hrhampapura","error":true,"key":"Kq8rvAkOhj"},{"type":"text","value":"\n","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"IvliNdUatX"},{"type":"link","url":"https://github.com/rpconroy","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Rile