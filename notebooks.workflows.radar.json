on":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OMME7YqRmu"}],"identifier":"visualizing-the-rhi-vertical-scan","label":"Visualizing the RHI (vertical) scan","html_id":"visualizing-the-rhi-vertical-scan","implicit":true,"key":"mXddUrrit5"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We extract the first sweep, compute each gate’s altitude from its range and\nelevation angle (accounting for Earth’s curvature), and plot reflectivity as a\nrange–altitude cross-section.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zOmsPoxZxC"}],"key":"ZWDFBLLQdk"}],"key":"U8aVEYpnrq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ds_rhi = dt_rhi[\"sweep_0\"].to_dataset()\n\n\ndef rhi_altitude(r, elevation_deg):\n    \"\"\"Beam altitude (km) from range (m) and elevation angle (deg), with Earth curvature.\"\"\"\n    r_earth = 6_371_000.0\n    e = np.deg2rad(elevation_deg)\n    return (np.sqrt(r**2 + r_earth**2 + 2 * r * r_earth * np.sin(e)) - r_earth) / 1000.0\n\n\nds_rhi[\"rhi_alt\"] = rhi_altitude(ds_rhi[\"range\"], ds_rhi[\"elevation\"]).compute()\nds_rhi = ds_rhi.set_coords(\"rhi_alt\")\nds_rhi[\"range\"] = ds_rhi[\"range\"] / 1000.0\nds_rhi[\"rhi_alt\"].attrs = {\"long_name\": \"RHI altitude\", \"units\": \"km\"}\nds_rhi[\"range\"].attrs[\"units\"] = \"km\"","key":"A1CK3ThuQG"},{"type":"outputs","id":"l7LbfcvQdpWUjyLzn6k4l","children":[],"key":"uiYyiLsVDO"}],"key":"ZtIBGlqEPE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(figsize=(16, 4))\nds_rhi[\"DBZ\"].plot.pcolormesh(\n    x=\"range\",\n    y=\"rhi_alt\",\n    cmap=\"ChaseSpectral\",\n    levels=np.arange(-10, 55, 1),\n    ax=ax,\n    cbar_kwargs={\"label\": \"Reflectivity (dBZ)\"},\n)\nax.set_xlabel(\"Range (km)\")\nax.set_ylabel(\"Altitude (km)\")\nax.set_xlim(0, 150)\nax.set_ylim(0, 15)\nax.set_title(\n    f\"S-Pol RHI reflectivity — 2022-05-25 \"\n    f\"(lon {ds_rhi.longitude.values:.2f}, lat {ds_rhi.latitude.values:.2f})\"\n)\nplt.show()","key":"uIyZVT0dDM"},{"type":"outputs","id":"zVWm_e2shp0nQRhi4gBjc","children":[],"key":"NTWhcJvbiC"}],"key":"YEWiOikljP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the PPI (horizontal) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NVD6lpiK04"}],"identifier":"visualizing-the-ppi-horizontal-scan","label":"Visualizing the PPI (horizontal) scan","html_id":"visualizing-the-ppi-horizontal-scan","implicit":true,"key":"W2GqzXoXFO"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For the surveillance scan we use ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Ov2Yqe2hVz"},{"type":"inlineCode","value":"xradar","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fCCedkkfnI"},{"type":"text","value":" to georeference the polar coordinates into\nCartesian ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wksUh8xsHn"},{"type":"inlineCode","value":"x","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oi8rCvQfkt"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fZojhCUwjy"},{"type":"inlineCode","value":"y","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dhj5dpVGFD"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yhyH5AdT73"},{"type":"inlineCode","value":"z","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NjrpPRx38Q"},{"type":"t