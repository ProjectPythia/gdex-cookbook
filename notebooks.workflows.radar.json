= xr.open_datatree(ppi_url, engine=\"zarr\", decode_timedelta=False)\ndt_rhi","key":"mJT1mWfkSC"},{"type":"outputs","id":"FR3uMBdEDHYwEA4VcQvsq","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m--------------------------------------------------------...","ename":"ConnectionTimeoutError","evalue":"Connection timeout to host https://osdfcache.ligo.caltech.edu:8443/ncar-gdex/d694517/v2.0_zarr/cfrad.20220525_015443.665_to_20220525_015709.985_SPOL_PrecipRhi2_RHI.zarr/sweep_6/time/c/0","hash":"27cfd5e1428e22bdadf00a07968d9008","path":"/gdex-cookbook/build/27cfd5e1428e22bdadf00a07968d9008.txt"},"key":"YJ6ajqc0RR"}],"key":"k4jUzZpB64"}],"key":"F6d9m9I0DH"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the RHI (vertical) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KwVCcEG6Nc"}],"identifier":"visualizing-the-rhi-vertical-scan","label":"Visualizing the RHI (vertical) scan","html_id":"visualizing-the-rhi-vertical-scan","implicit":true,"key":"hCsfTy8v97"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We extract the first sweep, compute each gate’s altitude from its range and\nelevation angle (accounting for Earth’s curvature), and plot reflectivity as a\nrange–altitude cross-section.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lXmxFG0uZe"}],"key":"dBXasllNcm"}],"key":"H9yGSq7z93"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ds_rhi = dt_rhi[\"sweep_0\"].to_dataset()\n\n\ndef rhi_altitude(r, elevation_deg):\n    \"\"\"Beam altitude (km) from range (m) and elevation angle (deg), with Earth curvature.\"\"\"\n    r_earth = 6_371_000.0\n    e = np.deg2rad(elevation_deg)\n    return (np.sqrt(r**2 + r_earth**2 + 2 * r * r_earth * np.sin(e)) - r_earth) / 1000.0\n\n\nds_rhi[\"rhi_alt\"] = rhi_altitude(ds_rhi[\"range\"], ds_rhi[\"elevation\"]).compute()\nds_rhi = ds_rhi.set_coords(\"rhi_alt\")\nds_rhi[\"range\"] = ds_rhi[\"range\"] / 1000.0\nds_rhi[\"rhi_alt\"].attrs = {\"long_name\": \"RHI altitude\", \"units\": \"km\"}\nds_rhi[\"range\"].attrs[\"units\"] = \"km\"","key":"fJrq5LnTbQ"},{"type":"outputs","id":"n0MnHpRM3OkLg1D5ytFLZ","children":[],"key":"HLcZgFeVnf"}],"key":"wNQu9rX0Ck"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(figsize=(16, 4))\nds_rhi[\"DBZ\"].plot.pcolormesh(\n    x=\"range\",\n    y=\"rhi_alt\",\n    cmap=\"ChaseSpectral\",\n    levels=np.arange(-10, 55, 1),\n    ax=ax,\n    cbar_kwargs={\"label\": \"Reflectivity (dBZ)\"},\n)\nax.set_xlabel(\"Range (km)\")\nax.set_ylabel(\"Altitude (km)\")\nax.set_xlim(0, 150)\nax.set_ylim(0, 15)\nax.set_title(\n    f\"S-Pol RHI reflectivity — 2022-05-25 \"\n    f\"(lon {ds_rhi.longitude.values:.2f}, lat {ds_rhi.latitude.values:.2f})\"\n)\nplt.show()","key":"FhtdGyDTCH"},{"type":"outputs","id":"d5nf54qGwiCsWubLdZfM9","children":[],"key":"KQkwccogdF"}],"key":"KThM9X8mpw"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the PPI (horizontal) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aNhbMC2sjY"}],"identifier":"visualizing-the-ppi-horizontal-scan","label":"Visualizing the PPI (horizontal) scan","html_id":"visualizing-the-ppi-horizontal-scan","implicit":true,"key":"BwL28gg1rW"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For the surveillance scan we use ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column