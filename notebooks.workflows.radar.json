n":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kE1ystDa9H"}],"identifier":"visualizing-the-rhi-vertical-scan","label":"Visualizing the RHI (vertical) scan","html_id":"visualizing-the-rhi-vertical-scan","implicit":true,"key":"lc5j8TqT4f"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We extract the first sweep, compute each gate’s altitude from its range and\nelevation angle (accounting for Earth’s curvature), and plot reflectivity as a\nrange–altitude cross-section.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"w8Vj2bqafv"}],"key":"dFfgo5vJXp"}],"key":"w9cH9sItA9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ds_rhi = dt_rhi[\"sweep_0\"].to_dataset()\n\n\ndef rhi_altitude(r, elevation_deg):\n    \"\"\"Beam altitude (km) from range (m) and elevation angle (deg), with Earth curvature.\"\"\"\n    r_earth = 6_371_000.0\n    e = np.deg2rad(elevation_deg)\n    return (np.sqrt(r**2 + r_earth**2 + 2 * r * r_earth * np.sin(e)) - r_earth) / 1000.0\n\n\nds_rhi[\"rhi_alt\"] = rhi_altitude(ds_rhi[\"range\"], ds_rhi[\"elevation\"]).compute()\nds_rhi = ds_rhi.set_coords(\"rhi_alt\")\nds_rhi[\"range\"] = ds_rhi[\"range\"] / 1000.0\nds_rhi[\"rhi_alt\"].attrs = {\"long_name\": \"RHI altitude\", \"units\": \"km\"}\nds_rhi[\"range\"].attrs[\"units\"] = \"km\"","key":"KMAACAAvKA"},{"type":"outputs","id":"IjulvtdhRdzQv6VDKuSis","children":[],"key":"qkDsT17OOT"}],"key":"Dz5Jq65beV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(figsize=(16, 4))\nds_rhi[\"DBZ\"].plot.pcolormesh(\n    x=\"range\",\n    y=\"rhi_alt\",\n    cmap=\"ChaseSpectral\",\n    levels=np.arange(-10, 55, 1),\n    ax=ax,\n    cbar_kwargs={\"label\": \"Reflectivity (dBZ)\"},\n)\nax.set_xlabel(\"Range (km)\")\nax.set_ylabel(\"Altitude (km)\")\nax.set_xlim(0, 150)\nax.set_ylim(0, 15)\nax.set_title(\n    f\"S-Pol RHI reflectivity — 2022-05-25 \"\n    f\"(lon {ds_rhi.longitude.values:.2f}, lat {ds_rhi.latitude.values:.2f})\"\n)\nplt.show()","key":"ACzoIq2WLe"},{"type":"outputs","id":"oz7i-MRg0sNnXR-6J90qp","children":[],"key":"ctPljRRvUO"}],"key":"PNwu7f8az6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the PPI (horizontal) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pZV6mEEC5z"}],"identifier":"visualizing-the-ppi-horizontal-scan","label":"Visualizing the PPI (horizontal) scan","html_id":"visualizing-the-ppi-horizontal-scan","implicit":true,"key":"NhhzKyDOi8"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For the surveillance scan we use ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"E9wnpxu1t6"},{"type":"inlineCode","value":"xradar","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tO94XVn6P1"},{"type":"text","value":" to georeference the polar coordinates into\nCartesian ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GzcMNiR3eT"},{"type":"inlineCode","value":"x","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QrfoyuKFLm"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"rBdNys7z7Y"},{"type":"inlineCode","value":"y","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"S6GOMMuBW8"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lKrgCf1Cjy"},{"type":"inlineCode","value":"z","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"aKIiHT8zSR"},{"type":"te