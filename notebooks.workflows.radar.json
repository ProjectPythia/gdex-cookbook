ernal Server Error', url='https://dtn-pas.hous.nrp.internet2.edu:8443/ncar-gdex/d694517/v2.0_zarr/cfrad.20220525_015443.665_to_20220525_015709.985_SPOL_PrecipRhi2_RHI.zarr/sweep_0/sweep_mode/c'","hash":"489d0795eebe512310fd390d1d90f2eb","path":"/gdex-cookbook/build/489d0795eebe512310fd390d1d90f2eb.txt"},"key":"fEMRo9plE6"}],"key":"yxnA1rK14j"}],"key":"lVVQQiemzR"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the RHI (vertical) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tfeGIzN9ys"}],"identifier":"visualizing-the-rhi-vertical-scan","label":"Visualizing the RHI (vertical) scan","html_id":"visualizing-the-rhi-vertical-scan","implicit":true,"key":"XeWeeIhnLd"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We extract the first sweep, compute each gate’s altitude from its range and\nelevation angle (accounting for Earth’s curvature), and plot reflectivity as a\nrange–altitude cross-section.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"TA2j6POR6U"}],"key":"QaaQV0gA1U"}],"key":"VNRduJecSN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ds_rhi = dt_rhi[\"sweep_0\"].to_dataset()\n\n\ndef rhi_altitude(r, elevation_deg):\n    \"\"\"Beam altitude (km) from range (m) and elevation angle (deg), with Earth curvature.\"\"\"\n    r_earth = 6_371_000.0\n    e = np.deg2rad(elevation_deg)\n    return (np.sqrt(r**2 + r_earth**2 + 2 * r * r_earth * np.sin(e)) - r_earth) / 1000.0\n\n\nds_rhi[\"rhi_alt\"] = rhi_altitude(ds_rhi[\"range\"], ds_rhi[\"elevation\"]).compute()\nds_rhi = ds_rhi.set_coords(\"rhi_alt\")\nds_rhi[\"range\"] = ds_rhi[\"range\"] / 1000.0\nds_rhi[\"rhi_alt\"].attrs = {\"long_name\": \"RHI altitude\", \"units\": \"km\"}\nds_rhi[\"range\"].attrs[\"units\"] = \"km\"","key":"uN4jN1DRGa"},{"type":"outputs","id":"bSwu0F6qoX-BCwKtXfxje","children":[],"key":"kN4x8eTSQD"}],"key":"yvaUDF10Ig"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(figsize=(16, 4))\nds_rhi[\"DBZ\"].plot.pcolormesh(\n    x=\"range\",\n    y=\"rhi_alt\",\n    cmap=\"ChaseSpectral\",\n    levels=np.arange(-10, 55, 1),\n    ax=ax,\n    cbar_kwargs={\"label\": \"Reflectivity (dBZ)\"},\n)\nax.set_xlabel(\"Range (km)\")\nax.set_ylabel(\"Altitude (km)\")\nax.set_xlim(0, 150)\nax.set_ylim(0, 15)\nax.set_title(\n    f\"S-Pol RHI reflectivity — 2022-05-25 \"\n    f\"(lon {ds_rhi.longitude.values:.2f}, lat {ds_rhi.latitude.values:.2f})\"\n)\nplt.show()","key":"pRmlCjDXXh"},{"type":"outputs","id":"2yUm3fyE7IyG8_Bb6WCmg","children":[],"key":"mnjaSWlx9C"}],"key":"yFID9aqHVP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the PPI (horizontal) scan","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZmaR5mZgKf"}],"identifier":"visualizing-the-ppi-horizontal-scan","label":"Visualizing the PPI (horizontal) scan","html_id":"visualizing-the-ppi-horizontal-scan","implicit":true,"key":"H6lENruMyT"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For the surveillance scan we use ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jiTD8EVuVj"},{"type":"inlineCode","value":"xradar","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"eplaxEI9Fr"},{"type":"text","value":" to georeference the polar coordinates into\nCartesian ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lJjMDsymwd"},{"type":"inlineCod