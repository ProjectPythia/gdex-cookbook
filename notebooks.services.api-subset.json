              # Optional, request output will be created in current working directory if 'targetdir' is not set to a desired output directory.  This option is only available for NCAR HPC users.\\n\"\n  },\n  \"contact\": \"datahelp@ucar.edu\"\n}\n"},"key":"AlOwI23dB9"}],"key":"hru0GpS9uq"}],"key":"pFb35KtTSu"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","kind":"tip","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Tip","key":"T70C8ZKRwy"}],"key":"H9mCcp6ISZ"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Store your GDEX token in an environment variable rather than hardcoding it:","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"wBvRUxJDmu"}],"key":"oYVokAJZ4f"},{"type":"code","lang":"bash","value":"export GDEX_TOKEN=\"your_token_here\"","position":{"start":{"line":4,"column":1},"end":{"line":6,"column":1}},"key":"NdHih3fDBf"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Retrieve your token from your ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"VAJq4llVAj"},{"type":"link","url":"https://gdex.ucar.edu/accounts/profile/","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"GDEX profile page","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"DyxrAxeAKl"}],"urlSource":"https://gdex.ucar.edu/accounts/profile/","key":"WpDtqL2vxG"},{"type":"text","value":".","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"skXA6VJtet"}],"key":"t2EVnHIgiX"}],"key":"N5lBrQiwGh"}],"key":"h5QXshPU2S"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Building the Control 