.75 -22.25\n    time_bnds  (time, bnds) datetime64[ns] 216kB dask.array<chunksize=(13514, 2), meta=np.ndarray>\nDimensions without coordinates: bnds\nData variables:\n    tmax       (member_id, time, lat, lon) float32 13GB dask.array<chunksize=(4, 1000, 65, 150), meta=np.ndarray>\nAttributes: (12/24)\n    CORDEX_domain:                  NAM-44\n    contact:                        {\"ERA-Int.CRCM5-UQAM\": \"Winger.Katja@uqam...\n    contact_note:                   {\"ERA-Int.RegCM4\": \"Simulations by Ray Ar...\n    creation_date:                  {\"ERA-Int.CRCM5-UQAM\": \"2015-06-18T10:56:...\n    driving_experiment:             {\"ERA-Int.CRCM5-UQAM\": \"ECMWF-ERAINT, eva...\n    driving_experiment_name:        evaluation\n    ...                             ...\n    references:                     {\"ERA-Int.CRCM5-UQAM\": \"http://www.mrcc.u...\n    title:                          {\"ERA-Int.CRCM5-UQAM\": \"NA-CORDEX Raw NAM...\n    tracking_id:                    {\"ERA-Int.CRCM5-UQAM\": \"a8d17321-0e16-46e...\n    version:                        {\"ERA-Int.CRCM5-UQAM\": \"1.2\", \"ERA-Int.Re...\n    zarr-dataset-reference:         For dataset documentation, see DOI https:...\n    zarr-version:                   1.0","content_type":"text/plain"},"text/html":{"content_type":"text/html","hash":"22b31fea9ef2556b0f4f6d2ed62fdad8","path":"/gdex-cookbook/build/22b31fea9ef2556b0f4f6d2ed62fdad8.html"}}},"key":"ThN8hJ7XkG"}],"key":"mUmiX6Hf29"}],"key":"i2EWE9SZJC"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Diagnostic plotting helpers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LQjGlu0tUs"}],"identifier":"diagnostic-plotting-helpers","label":"Diagnostic plotting helpers","html_id":"diagnostic-plotting-helpers","implicit":true,"key":"tmepGZkRfX"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Three small helpers: one to draw a single map with its min/max annotated, one to\nfind the first and last timesteps that actually contain data (NA-CORDEX runs have\ndifferent valid date ranges), and one to assemble a grid of first/middle/last maps\nfor several members.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GMc9194Y2g"}],"key":"kDqNOcKpCs"}],"key":"yhxGQeLdpS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plotMap(ax, map_slice, date_object=None, member_id=None):\n    \"\"\"Draw a single map on `ax`, annotating spatial min/max.\"\"\"\n    ax.imshow(map_slice, origin=\"lower\")\n\n    minval = map_slice.min(dim=[\"lat\", \"lon\"])\n    maxval = map_slice.max(dim=[\"lat\", \"lon\"])\n    ax.text(0.01, 0.03, \"Min: %3g\" % minval, transform=ax.transAxes, fontsize=12)\n    ax.text(0.99, 0.03, \"Max: %3g\" % maxval, transform=ax.transAxes, fontsize=12, horizontalalignment=\"right\")\n\n    ax.set_xticks([])\n    ax.set_yticks([])\n    if date_object is not None:\n        ax.set_title(date_object.values.astype(str)[:10], fontsize=12)\n    if member_id is not None:\n        ax.set_ylabel(member_id, fontsize=12)\n    return ax","key":"npZFgF1uaU"},{"type":"outputs","id":"RdlXQKgweUCKbQb-HgVKG","children":[],"key":"xYQJ6gYKHc"}],"key":"XSQLRYnWPQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def getValidDateIndexes(member_slice):\n    \"\"\"Return the indexes of the first and last timesteps with finite values.\"\"\"\n    min_values = member_slice.min(dim=[\"lat\", \"lon\"])\n    finite_indexes = np.where(np.isfinite(min_values))\n    return finite_indexes[0][0], finite_indexes[0][-1]","key":"UvpnGLMVrn"},{"type":"outputs","id":"4fKCuPMvy4qdXTBjxpHIW","children":[],"key":"rW7VxD3JQF"}],"key":"n2MGPXOjEZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_first_mid_last(ds, data_var, store_name):\n    \"\"\"Plot first, middle, and final valid timesteps for several model runs.\"\"\"\n    num_members_to_plot = 4\n    member_names = ds.coords[\"member_id\"].values[0:num_members_to_plot]\n\n    fig, axs = plt.subplots(num_members_to_plot, 3, figsize=(18, 12), constrained_layout=True)\n\n    for index in np.arange(num_members_to_plot):\n        mem_id = member_names[index]\n        data_slice = ds[data_var].sel(member_id=mem_id)\n\n        start_index, end_index = getValidDateIndexes(data_slice)\n        mid_index = np.floor(len(ds.time) / 2).astype(int)\n\n        for col, t_index in enumerate([start_index, mid_index, end_index]):\n            date = ds.time[t_index]\n            step = data_slice.sel(time=date)\n            plotMap(axs[index, col], step, date, mem_id if col == 0 else None)\n\n    plt.suptitle(f'First, middle, and last timesteps for selected runs in \"{store_name}\"', fontsize=20)\n    return fig","key":"j1f5zNkoMa"},{"type":"outputs","id":"dJhexNViYVilP4coqalcS","children":[],"key":"L58r7vyuKW"}],"key":"Op0eHyP0yB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting first, middle, and last timesteps","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MqzQ6Z05SV"}],"identifier":"plotting-first-middle-and-last-timesteps","label":"Plotting first, middle, and last timesteps","html_id":"plotting-first-middle-and-last-timesteps","implicit":true,"key":"QoUlQzhPoW"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"This is the lightest of the diagnostics — it reads only a handful of 2D slices per\nmember (plus a per-member finite-value scan to find valid dates).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"LTxGsi6ywB"}],"key":"y7M8hiGRv4"}],"key":"nmO7kV62sl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nplot_first_mid_last(ds, data_var, store_name)\nplt.show()","key":"VgKbtX0UWC"},{"type":"outputs","id":"_2xPxgNMWJNnZEmAgBq09","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1800x1200 with 12 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"cf72684bb275794c658d0326b1841682","path":"/gdex-cookbook/build/cf72684bb275794c658d0326b1841682.png"}}},"key":"Woi4Ws0jNS"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 8.56 s, sys: 1.87 s, total: 10.4 s\nWall time: 1min 56s\n"},"key":"S2HGFPXq0E"}],"key":"Chs3C0LtCE"}],"key":"vRG2evVr1w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"s4BKIRdOHh"},{"type":"outputs","id":"aF2pwVCKGO4loDAyg3h_3","children":[],"key":"HIMYCMvvOp"}],"key":"Kkf8x0kCQX"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VH1PLmrZm4"}],"key":"Fl5B2QpK9W"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BxqIgI6l2s"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"Kt1ubM4tPO"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We opened NA-CORDEX daily maximum temperature directly from