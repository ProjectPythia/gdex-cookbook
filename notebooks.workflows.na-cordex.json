date ranges), and one to assemble a grid of first/middle/last maps\nfor several members.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"rVdEBvxRpK"}],"key":"npgvxH4fQj"}],"key":"IG9Mbd6a4h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plotMap(ax, map_slice, date_object=None, member_id=None):\n    \"\"\"Draw a single map on `ax`, annotating spatial min/max.\"\"\"\n    ax.imshow(map_slice, origin=\"lower\")\n\n    minval = map_slice.min(dim=[\"lat\", \"lon\"])\n    maxval = map_slice.max(dim=[\"lat\", \"lon\"])\n    ax.text(0.01, 0.03, \"Min: %3g\" % minval, transform=ax.transAxes, fontsize=12)\n    ax.text(0.99, 0.03, \"Max: %3g\" % maxval, transform=ax.transAxes, fontsize=12, horizontalalignment=\"right\")\n\n    ax.set_xticks([])\n    ax.set_yticks([])\n    if date_object is not None:\n        ax.set_title(date_object.values.astype(str)[:10], fontsize=12)\n    if member_id is not None:\n        ax.set_ylabel(member_id, fontsize=12)\n    return ax","key":"SppG1IFlli"},{"type":"outputs","id":"jayqgXbjcwmhyT3L42Gd8","children":[],"key":"rsZpOAii4t"}],"key":"bOz2Prlohg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def getValidDateIndexes(member_slice):\n    \"\"\"Return the indexes of the first and last timesteps with finite values.\"\"\"\n    min_values = member_slice.min(dim=[\"lat\", \"lon\"])\n    finite_indexes = np.where(np.isfinite(min_values))\n    return finite_indexes[0][0], finite_indexes[0][-1]","key":"KWURf80Wgj"},{"type":"outputs","id":"qwhv88f59LS3k8eLp6VCi","children":[],"key":"ITeJzruHpR"}],"key":"bBTaTWhQJA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_first_mid_last(ds, data_var, store_name):\n    \"\"\"Plot first, middle, and final valid timesteps for several model runs.\"\"\"\n    num_members_to_plot = 4\n    member_names = ds.coords[\"member_id\"].values[0:num_members_to_plot]\n\n    fig, axs = plt.subplots(num_members_to_plot, 3, figsize=(18, 12), constrained_layout=True)\n\n    for index in np.arange(num_members_to_plot):\n        mem_id = member_names[index]\n        data_slice = ds[data_var].sel(member_id=mem_id)\n\n        start_index, end_index = getValidDateIndexes(data_slice)\n        mid_index = np.floor(len(ds.time) / 2).astype(int)\n\n        for col, t_index in enumerate([start_index, mid_index, end_index]):\n            date = ds.time[t_index]\n            step = data_slice.sel(time=date)\n            plotMap(axs[index, col], step, date, mem_id if col == 0 else None)\n\n    plt.suptitle(f'First, middle, and last timesteps for selected runs in \"{store_name}\"', fontsize=20)\n    return fig","key":"QiED5UMqYl"},{"type":"outputs","id":"tPur_9HBOLG1DXtuhyCiC","children":[],"key":"lXBDiptr9h"}],"key":"beWhWN9u9T"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting first, middle, and last timesteps","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n0qGKPexLv"}],"identifier":"plotting-first-middle-and-last-timesteps","label":"Plotting first, middle, and last timesteps","html_id":"plotting-first-middle-and-last-timesteps","implicit":true,"key":"chXEQRxvdQ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"This is the lightest of the diagnostics — it reads only a handful of 2D slices per\nmember (plus a per-member finite-value scan to find valid dates).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xcIF9ttBF6"}],"key":"ESTj1xFG1z"}],"key":"JG5DGK9i1W"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nplot_first_mid_last(ds, data_var, store_name)\nplt.show()","key":"wmTOj0acc5"},{"type":"outputs","id":"NB3DaZ_Ocslerb02GRNEi","children":[],"key":"K6P6UWR7FR"}],"key":"gNY2AcMjzi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"CJF1LkxWxc"},{"type":"outputs","id":"7PnbKwMo1GW5W3xMp-Uk5","children":[],"key":"phA4t7tkuS"}],"key":"OGNdmO9rgR"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"j9jGTjYrtB"}],"key":"GE1bHh3QDI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Npbhro6NWe"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"oYZbiKsVxf"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We opened NA-CORDEX daily maximum temperature directly from GDEX’s OSDF Zarr store,\nspun up a ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"iiCkRRwxoN"},{"type":"inlineCode","value":"LocalCluster","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"VrNMhNcYNK"},{"type":"text","value":", and produced first/middle/last diagnostic maps across\nseveral regional-model runs — a quick way to sanity-check a multi-member dataset.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sGw5kHGAi7"}],"key":"sV2ZfvpA0W"},{"type":"heading","depth":3,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"QbN117HTVy"}],"identifier":"whats-next","lab