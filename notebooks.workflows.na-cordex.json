e":"text","value":"Diagnostic plotting helpers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bIWg9JhIOA"}],"identifier":"diagnostic-plotting-helpers","label":"Diagnostic plotting helpers","html_id":"diagnostic-plotting-helpers","implicit":true,"key":"nfFfcMzStL"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Three small helpers: one to draw a single map with its min/max annotated, one to\nfind the first and last timesteps that actually contain data (NA-CORDEX runs have\ndifferent valid date ranges), and one to assemble a grid of first/middle/last maps\nfor several members.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oDZaLWwmIX"}],"key":"r5tvW7dk5n"}],"key":"w8ftGz3G7h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plotMap(ax, map_slice, date_object=None, member_id=None):\n    \"\"\"Draw a single map on `ax`, annotating spatial min/max.\"\"\"\n    ax.imshow(map_slice, origin=\"lower\")\n\n    minval = map_slice.min(dim=[\"lat\", \"lon\"])\n    maxval = map_slice.max(dim=[\"lat\", \"lon\"])\n    ax.text(0.01, 0.03, \"Min: %3g\" % minval, transform=ax.transAxes, fontsize=12)\n    ax.text(0.99, 0.03, \"Max: %3g\" % maxval, transform=ax.transAxes, fontsize=12, horizontalalignment=\"right\")\n\n    ax.set_xticks([])\n    ax.set_yticks([])\n    if date_object is not None:\n        ax.set_title(date_object.values.astype(str)[:10], fontsize=12)\n    if member_id is not None:\n        ax.set_ylabel(member_id, fontsize=12)\n    return ax","key":"SburTueJPw"},{"type":"outputs","id":"GJejCT7dOhnom_1JNxWZT","children":[],"key":"ahQ1HRIMes"}],"key":"Rb8uJ57u1w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def getValidDateIndexes(member_slice):\n    \"\"\"Return the indexes of the first and last timesteps with finite values.\"\"\"\n    min_values = member_slice.min(dim=[\"lat\", \"lon\"])\n    finite_indexes = np.where(np.isfinite(min_values))\n    return finite_indexes[0][0], finite_indexes[0][-1]","key":"rEdoUkauYr"},{"type":"outputs","id":"Rc-R_LhuFN7V4mHfc7XCm","children":[],"key":"vQeG8DsUQj"}],"key":"U5CEZYR2Fw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_first_mid_last(ds, data_var, store_name):\n    \"\"\"Plot first, middle, and final valid timesteps for several model runs.\"\"\"\n    num_members_to_plot = 4\n    member_names = ds.coords[\"member_id\"].values[0:num_members_to_plot]\n\n    fig, axs = plt.subplots(num_members_to_plot, 3, figsize=(18, 12), constrained_layout=True)\n\n    for index in np.arange(num_members_to_plot):\n        mem_id = member_names[index]\n        data_slice = ds[data_var].sel(member_id=mem_id)\n\n        start_index, end_index = getValidDateIndexes(data_slice)\n        mid_index = np.floor(len(ds.time) / 2).astype(int)\n\n        for col, t_index in enumerate([start_index, mid_index, end_index]):\n            date = ds.time[t_index]\n            step = data_slice.sel(time=date)\n            plotMap(axs[index, col], step, date, mem_id if col == 0 else None)\n\n    plt.suptitle(f'First, middle, and last timesteps for selected runs in \"{store_name}\"', fontsize=20)\n    return fig","key":"cznMmgIoyd"},{"type":"outputs","id":"x8ptZ0vrzldAwxA8Gjh1b","children":[],"key":"t8afV66Ck6"}],"key":"K3XpswTbSG"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting first, middle, and last timesteps","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TUJEUyk7z7"}],"identifier":"plotting-first-middle-and-last-timesteps","label":"Plotting first, middle, and last timesteps","html_id":"plotting-first-middle-and-last-timesteps","implicit":true,"key":"moS19unac7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"This is the lightest of the diagnostics — it reads only a handful of 2D slices per\nmember (plus a per-member finite-value scan to find valid dates).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pzGHhZoKH3"}],"key":"PbmtbhYgkf"}],"key":"vYCyO9pmGp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nplot_first_mid_last(ds, data_var, store_name)\nplt.show()","key":"kkJpQimOHS"},{"type":"outputs","id":"I9W_WK3NjNTvYZmuhJm0w","children":[],"key":"E5yvMZIz7T"}],"key":"fk2jZ5Hpas"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"rELYvxV9kZ"},{"type":"outputs","id":"3Fl-JGkAGeVSdxgpk96l4","children":[],"key":"Dy9GExOhvq"}],"key":"DCk0Z936dr"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zpfp6pgbDj"}],"key":"JO1lM4GiJf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"R6m0LYJrge"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"fQs0jmInDT"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We opened NA-CORDEX daily maximum temperature directly from GDEX’s OSDF Zarr store,\nspun up a ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"aJuipTwPEz"},{"type":"inlineCode","value":"LocalCluster","position":{"start":{"line":3,"co