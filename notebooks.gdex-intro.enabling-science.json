 = ds[variable]\n        if time_slice:\n            da = da.sel(time=time_slice)\n        self.data = da.values  # loads into memory; use .chunk() + dask for lazy\n\n    def __len__(self):\n        return self.data.shape[0]\n\n    def __getitem__(self, idx):\n        return torch.tensor(self.data[idx], dtype=torch.float32)","position":{"start":{"line":72,"column":1},"end":{"line":91,"column":1}},"key":"ISZI2lJYuy"},{"type":"paragraph","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"For datasets too large to fit in memory, pair Zarr with ","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"tpFc2kBkvF"},{"type":"link","url":"https://dask.org/","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"Dask","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"d2wh10bkqs"}],"urlSource":"https://dask.org/","key":"BPyAtUKtmM"},{"type":"text","value":" to build lazy pipelines that process one chunk at a time during training.","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"UofI6l4JD9"}],"key":"MBsYxog1Xz"},{"type":"admonition","kind":"caution","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Caution","key":"JWedU4HDoc"}],"key":"IQTqPu2K1O"},{"type":"paragraph","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"inlineCode","value":"self.data = da.values","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"MH8GGn67Ux"},{"type":"text","value":" loads the entire array into memory at initialization. For datasets larger than available RAM, keep the data lazy with ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"oaW3VqLofU"},{"type":"inlineCode","value":"da.chunk({...})","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"UmDoqo