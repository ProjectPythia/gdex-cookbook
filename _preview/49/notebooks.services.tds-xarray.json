, 2, figsize=(13, 4.5),\n    subplot_kw={\"projection\": ccrs.PlateCarree()}\n)\n\nfor ax, lev in zip(axes, [1000, 500]):\n    da = subset.sel(level=lev)\n    im = da.plot(\n        ax=ax,\n        transform=ccrs.PlateCarree(),\n        cmap=\"coolwarm\",\n        add_colorbar=False\n    )\n    ax.coastlines()\n    ax.set_extent([230, 300, 20, 55], crs=ccrs.PlateCarree())\n    ax.set_title(f\"T at {lev} hPa (time=0)\")\n\nfig.colorbar(im, ax=axes, orientation=\"horizontal\", pad=0.08, label=\"Temperature (K)\")\nplt.tight_layout()\n# Use RdBu_r colormap on both panels (and linked colorbar mappable)\nfor a in axes:\n    if a.collections:\n        a.collections[0].set_cmap(\"RdBu_r\")\nim.set_cmap(\"RdBu_r\")\n\n# Put actual datetime in titles\ntime_str = subset.time.dt.strftime(\"%Y-%m-%d %H:%M UTC\").item()\nfor a, lev in zip(axes, subset.level.values):\n    a.set_title(f\"T at {int(lev)} hPa ({time_str})\")\n\n# Move colorbar down to avoid overlap\nfig.subplots_adjust(bottom=0.18)\ncbar_ax = fig.axes[-1]\npos = cbar_ax.get_position()\ncbar_ax.set_position([pos.x0, pos.y0 - 0.1, pos.width, pos.height])\n\nplt.show()","key":"vaCGIo8izN"},{"type":"outputs","id":"KNV1FO887UEmJLoq9IKFY","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_5165/1146481999.py:26: UserWarning: This figure includes Axes that are not compatible with tight_layout, so results might be incorrect.\n  plt.tight_layout()\n"},"key":"tHOHspUQ7U"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1300x450 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"d8cd90b59aef66e5cfe8de13f41d8fbd","path":"/gdex-cookbook/_preview/49/build/d8cd90b59aef66e5cfe8de13f41d8fbd.png"}}},"key":"a9RRyUApal"}],"key":"r382Ti1vwO"}],"key":"SJKbzJy8wG"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","po