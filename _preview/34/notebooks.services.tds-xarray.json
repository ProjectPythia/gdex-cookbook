ppable)\nfor a in axes:\n    if a.collections:\n        a.collections[0].set_cmap(\"RdBu_r\")\nim.set_cmap(\"RdBu_r\")\n\n# Put actual datetime in titles\ntime_str = subset.time.dt.strftime(\"%Y-%m-%d %H:%M UTC\").item()\nfor a, lev in zip(axes, subset.level.values):\n    a.set_title(f\"T at {int(lev)} hPa ({time_str})\")\n\n# Move colorbar down to avoid overlap\nfig.subplots_adjust(bottom=0.18)\ncbar_ax = fig.axes[-1]\npos = cbar_ax.get_position()\ncbar_ax.set_position([pos.x0, pos.y0 - 0.1, pos.width, pos.height])\n\nplt.show()","key":"Xz2v5NBSbH"},{"type":"outputs","id":"ut17oCy98hBskiTShMocj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4985/1146481999.py:26: UserWarning: This figure includes Axes that are not compatible with tight_layout, so results might be incorrect.\n  plt.tight_layout()\n"},"key":"Ia1EOreu5M"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1300x450 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"d8cd90b59aef66e5cfe8de13f41d8fbd","path":"/gdex-cookbook/_preview/34/build/d8cd90b59aef66e5cfe8de13f41d8fbd.png"}}},"key":"e8cRqy9aiM"}],"key":"iJrwa4UJef"}],"key":"Y2wqGD7QW2"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kc6aw8o4HM"}],"key":"xZNkyZviEh"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uN5M8elt2x"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"QDFppMwFQL"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":