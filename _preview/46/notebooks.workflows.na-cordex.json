:{"line":1,"column":1}},"children":[{"type":"text","value":"Diagnostic plotting helpers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uLAmNmPNTc"}],"identifier":"diagnostic-plotting-helpers","label":"Diagnostic plotting helpers","html_id":"diagnostic-plotting-helpers","implicit":true,"key":"nedPBj4Y4r"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Three small helpers: one to draw a single map with its min/max annotated, one to\nfind the first and last timesteps that actually contain data (NA-CORDEX runs have\ndifferent valid date ranges), and one to assemble a grid of first/middle/last maps\nfor several members.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jdGz2ZFWEU"}],"key":"cjWtS7OumR"}],"key":"DUIk9aelnp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plotMap(ax, map_slice, date_object=None, member_id=None):\n    \"\"\"Draw a single map on `ax`, annotating spatial min/max.\"\"\"\n    ax.imshow(map_slice, origin=\"lower\")\n\n    minval = map_slice.min(dim=[\"lat\", \"lon\"])\n    maxval = map_slice.max(dim=[\"lat\", \"lon\"])\n    ax.text(0.01, 0.03, \"Min: %3g\" % minval, transform=ax.transAxes, fontsize=12)\n    ax.text(0.99, 0.03, \"Max: %3g\" % maxval, transform=ax.transAxes, fontsize=12, horizontalalignment=\"right\")\n\n    ax.set_xticks([])\n    ax.set_yticks([])\n    if date_object is not None:\n        ax.set_title(date_object.values.astype(str)[:10], fontsize=12)\n    if member_id is not None:\n        ax.set_ylabel(member_id, fontsize=12)\n    return ax","key":"GmIFjITcJK"},{"type":"outputs","id":"PakwpFiayJFpyBpOIGKZS","children":[],"key":"hqaYl2D4VW"}],"key":"cFwyhpxTJ6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def getValidDateIndexes(member_slice):\n    \"\"\"Return the indexes of the first and last timesteps with finite values.\"\"\"\n    min_values = member_slice.min(dim=[\"lat\", \"lon\"])\n    finite_indexes = np.where(np.isfinite(min_values))\n    return finite_indexes[0][0], finite_indexes[0][-1]","key":"RBz7PbCXG9"},{"type":"outputs","id":"iiApLWftNN-nbQBGn-s_6","children":[],"key":"XSZSLdXmzL"}],"key":"kR9qIvO4sk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_first_mid_last(ds, data_var, store_name):\n    \"\"\"Plot first, middle, and final valid timesteps for several model runs.\"\"\"\n    num_members_to_plot = 4\n    member_names = ds.coords[\"member_id\"].values[0:num_members_to_plot]\n\n    fig, axs = plt.subplots(num_members_to_plot, 3, figsize=(18, 12), constrained_layout=True)\n\n    for index in np.arange(num_members_to_plot):\n        mem_id = member_names[index]\n        data_slice = ds[data_var].sel(member_id=mem_id)\n\n        start_index, end_index = getValidDateIndexes(data_slice)\n        mid_index = np.floor(len(ds.time) / 2).astype(int)\n\n        for col, t_index in enumerate([start_index, mid_index, end_index]):\n            date = ds.time[t_index]\n            step = data_slice.sel(time=date)\n            plotMap(axs[index, col], step, date, mem_id if col == 0 else None)\n\n    plt.suptitle(f'First, middle, and last timesteps for selected runs in \"{store_name}\"', fontsize=20)\n    return fig","key":"chBOhhGpAI"},{"type":"outputs","id":"Ut2eUwRPlsLFjnqN2keuH","children":[],"key":"QNhzqqPAzU"}],"key":"P0xfTtSnzQ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting first, middle, and last timesteps","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wfavhcgeLd"}],"identifier":"plotting-first-middle-and-last-timesteps","label":"Plotting first, middle, and last timesteps","html_id":"plotting-first-middle-and-last-timesteps","implicit":true,"key":"PwcqkYKB8a"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"This is the lightest of the diagnostics — it reads only a handful of 2D slices per\nmember (plus a per-member finite-value scan to find valid dates).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JHQLHPUrf2"}],"key":"GbgrrJ6yRe"}],"key":"mB8Djj2aLh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nplot_first_mid_last(ds, data_var, store_name)\nplt.show()","key":"Q7rks8vyKU"},{"type":"outputs","id":"AZbV4NfT6ac2AB5xbRHJG","children":[],"key":"qc5n7gPkmm"}],"key":"nbaq9Dkr6j"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"SNukYRjMvt"},{"type":"outputs","id":"mkm4cxAdm_cg2_DDfaqfO","children":[],"key":"zKl308hjtE"}],"key":"b7gTnzjbB9"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GIOpbml3t4"}],"key":"M5fdJguAfz"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ocot6oFstU"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"kZUs8tNbJC"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"We opened NA-CORDEX daily maximum temperature directly from GDEX’s OSDF Zarr store,\nspun up a ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sf8tZMoCYE"},{"type":"inlineCode","value":"LocalC