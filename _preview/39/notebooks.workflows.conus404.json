"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ewu22T9Uoh"}],"key":"f1eiMapoit"},{"type":"text","value":" CONUS404 variables (","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kyWkzmcDZ0"},{"type":"inlineCode","value":"wrf2d","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JHNRgklc64"},{"type":"text","value":") —\nprecipitation, 2-m temperature, surface fluxes, and more. We open it over HTTPS and\npull out hourly accumulated precipitation, ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PORF7d2c8t"},{"type":"inlineCode","value":"PREC_ACC_NC","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YDH4YXnYaT"},{"type":"text","value":" (mm), along with the static\n2D lat/lon needed for mapping.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Og5cSMIVZc"}],"key":"Wt8xutQtyR"}],"key":"eOfX62Lrr0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nkerchunk_url = \"https://data.gdex.ucar.edu/d559000/kerchunk/wrf2d-remote-https.parq\"\n\nds = xr.open_dataset(kerchunk_url, engine=\"kerchunk\", \\\n                     storage_options={\"remote_protocol\": \"https\"})\npr = ds[\"PREC_ACC_NC\"]\nlat2d = ds[\"XLAT\"].isel(Time=0)\nlon2d = ds[\"XLONG\"].isel(Time=0)\npr","key":"whAWJvtzBj"},{"type":"outputs","id":"-3Ga27Eiss-1sKmExeoD_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 10.2 s, sys: 2.74 s, total: 12.9 s\nWall time: 5min 2s\n"},"key":"ZJ9TX0In5f"},{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m--------------------------------------------------------...","ename":"FSTimeoutError","evalue":"","hash":"c52659722eba9ef162570337f8c3dd42","path":"/gdex-cookbook/_preview/39/build/c52659722eba9ef162570337f8c3dd42.txt"},"key":"GOZ8Fs7f1D"}],"key":"Hburl2DVLr"}],"key":"AH5yoUNUQD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nmonth = \"2017-02\"\npr_month = pr.sel(Time=month).sum(\"Time\").compute()","key":"VLaY1wVGcf"},{"type":"outputs","id":"0lMzjDmcMRVJpLOWUEcut","children":[],"key":"nSB7bizyD0"}],"key":"iESd81nr49"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Mapping the monthly total","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uzVGH7IbVG"}],"identifier":"mapping-the-monthly-total","label":"Mapping the monthly total","html_id":"mapping-the-monthly-total","implicit":true,"key":"TwlJDN9XjP"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"CONUS404 sits on a Lambert Conformal grid. We coarsen 4× for plotting (to spare\nCartopy memory) and use the NCL ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vaN8Vol7Pv"},{"type":"inlineCode","value":"precip3_16lev","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lvrvC6DSbU"},{"type":"text","value":" palette.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"RFIFpbxiTv"}],"key":"fzGzvfcTTT"}],"key":"VxUITJ2zU6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"proj = ccrs.LambertConformal(central_longitude=-97.5, central_latitude=38.5)\ntrans = ccrs.PlateCarree()\n\n_rgb255 = [\n    (255, 255, 255), (214, 226, 255), (181, 201, 255), (142, 178, 255),\n    (127, 150, 255), (114, 133, 248), (99, 112, 248), (0, 158, 30),\n    (60, 188, 61), (179, 209, 110), (185, 249, 110), (255, 249, 19),\n    (255, 163, 9), (229, 0, 0), (189, 0, 31), (165, 0, 33),\n]\ncmap_pr = ListedColormap(np.array(_rgb255) / 255, name=\"precip3_16lev\")\nlevels = np.arange(0, 301, 20)\nnorm = BoundaryNorm(levels, ncolors=cmap_pr.N, extend=\"max\")\n\nkw = dict(south_north=4, west_east=4, boundary=\"trim\")\npr_plot = pr_month.coarsen(**kw).mean()\nlat_plot = lat2d.coarsen(**kw).mean()\nlon_plot = lon2d.coarsen(**kw).mean()\n\nfig, ax = plt.subplots(figsize=(11, 7), subplot_kw={\"projection\": proj})\nim = ax.pcolormesh(\n    lon_plot.values, lat_plot.values, pr_plot.values,\n    transform=trans, cmap=cmap_pr, norm=norm, shading=\"auto\",\n)\nax.add_feature(cfeature.COASTLINE, lw=0.4)\nax.add_feature(cfeature.BORDERS, lw=0.4)\nax.add_feature(cfeature.STATES, lw=0.2)\nax.set_extent([-125, -66, 24, 50], crs=trans)\n\nfig.colorbar(im, ax=ax, shrink=0.7, ticks=levels, extend=\"max\",\n             label=\"Monthly precipitation (mm)\")\nax.set_title(\"CONUS404 total precipitation — February 2017\")\nplt.show()","key":"a7KaZVqmem"},{"type":"outputs","id":"vAeroU4zO8ChXHlwZgWqo","children":[],"key":"mmSsaGA4aP"}],"key":"kK2WPp1AO2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"client.close()\ncluster.close()","key":"NMkGod5P0W"},{"type":"outputs","id":"WrqNXLJA9cvAgUEVwYCQU","children":[],"key":"W4BAwS4HyX"}],"key":"wncTtIroj0"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mBdPJO7IPe"}],"key":"MYTghYHjLg"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Oe0Td1bWUH"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"ZUo5kdeK75"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"We opene