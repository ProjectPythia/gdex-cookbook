,"key":"b2ePpFQVrm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://osdf-director.osg-htc.org/ncar/gdex/d277003/HadISST_sst.nc.gz\"\n\nresponse = requests.get(url)\nresponse.raise_for_status()\nraw = gzip.decompress(response.content)\n\nwith tempfile.NamedTemporaryFile(suffix=\".nc\") as tmp:\n    tmp.write(raw)\n    tmp.flush()\n    ds = xr.open_dataset(tmp.name, engine=\"scipy\", decode_times=False)\n\nds = xr.decode_cf(ds)\nds","key":"Emwp810q0W"},{"type":"outputs","id":"AJVeOhdQP9hXwRSfWFsUy","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"error","traceback":"\u001b[31m---------------------------------------------------------------------------\u001b[39m\n\u001b[31mHTTPError\u001b[39m                                 Traceback (most recent call last)\n\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[2]\u001b[39m\u001b[32m, line 4\u001b[39m\n\u001b[32m      1\u001b[39m url = \u001b[33m\"https://osdf-director.osg-htc.org/ncar/gdex/d277003/HadISST_sst.nc.gz\"\u001b[39m\n\u001b[32m      2\u001b[39m \n\u001b[32m      3\u001b[39m response = requests.get(url)\n\u001b[32m----> \u001b[39m\u001b[32m4\u001b[39m response.raise_for_status()\n\u001b[32m      5\u001b[39m raw = gzip.decompress(response.content)\n\u001b[32m      6\u001b[39m \n\u001b[32m      7\u001b[39m \u001b[38;5;28;01mwith\u001b[39;00m tempfile.NamedTemporaryFile(suffix=\u001b[33m\".nc\"\u001b[39m) \u001b[38;5;28;01mas\u001b[39;00m tmp:\n\n\u001b[36mFile \u001b[39m\u001b[32m~/micromamba/envs/gdex-cookbook/lib/python3.12/site-packages/requests/models.py:1167\u001b[39m, in \u001b[36mResponse.raise_for_status\u001b[39m\u001b[34m(self)\u001b[39m\n\u001b[32m   1162\u001b[39m     http_error_msg = (\n\u001b[32m   1163\u001b[39m         \u001b[33mf\u001b[39m\u001b[33m\"\u001b[39m\u001b[38;5;132;01m{\u001b[39;00m\u001b[38;5;28mself\u001b[39m.status_code\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m Server Error: \u001b[39m\u001b[38;5;132;01m{\u001b[39;00mreason\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m for url: \u001b[39m\u001b[38;5;132;01m{\u001b[39;00m\u001b[38;5;28mself\u001b[39m.url\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m\"\u001b[39m\n\u001b[32m   1164\u001b[39m     )\n\u001b[32m   1166\u001b[39m \u001b[38;5;28;01mif\u001b[39;00m http_error_msg:\n\u001b[32m-> \u001b[39m\u001b[32m1167\u001b[39m     \u001b[38;5;28;01mraise\u001b[39;00m HTTPError(http_error_msg, response=\u001b[38;5;28mself\u001b[39m)\n\n\u001b[31mHTTPError\u001b[39m: 404 Client Error: Not Found for url: https://osdf-director.osg-htc.org/ncar/gdex/d277003/HadISST_sst.nc.gz","ename":"HTTPError","evalue":"404 Client Error: Not Found for url: https://osdf-director.osg-htc.org/ncar/gdex/d277003/HadISST_sst.nc.gz"},"key":"ylYSTCuEOP"}],"key":"Bqdr6XzCPr"}],"key":"fnvo0yDGFE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Preparing the SST field","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NFUZQwFtUy"}],"identifier":"preparing-the-sst-field","label":"Preparing the SST field","html_id":"preparing-the-sst-field","implicit":true,"key":"tfIuwrsPx7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"HadISST flags land and missing values with large negative numbers, and uses\nlongitudes from −180° to 180°. We mask the fill values and convert to a 0–360°\nlongitude convention so the Pacific Niño regions form contiguous boxes.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xSwo3eaJTi"}],"key":"YKjI8Hm8lD"}],"key":"ls3LRKi6ZC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def lon_to_360(da):\n    lon_name = \"lon\" if \"lon\" in da.coords else \"longitude\"\n    lon360 = da[lon_name] % 360\n    return da.assign_coords({lon_name: lon360}).sortby(lon_name)\n\n\nsst = lon_to_360(ds[\"sst\"])\nsst = sst.where(sst > -100)  # mask land and fill values","key":"A4mvBNrPHl"},{"type":"outputs","id":"q29X_zqbGemqw-TT0dVkf","children":[],"key":"i2w8ZGW7NQ"}],"key":"UB8oWMyU5c"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Defining the Niño regions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l8kYsAmqQE"}],"identifier":"defining-the-ni-o-regions","label":"Defining the Niño regions","html_id":"defining-the-ni-o-regions","implicit":true,"key":"gXKYY4vdLp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"ENSO is monitored over several boxes spanning the equatorial Pacific. We define the\nstandard four — Niño 1+2, 3, 3.4, and 4 — running from the South American coast\nwestward into the central Pacific.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"VfQKQNbRHP"}],"key":"rM2M56IcqY"}],"key":"WnodrBuQVz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def area_mean(da):\n    weights = np.cos(np.deg2rad(da[\"latitude\"]))\n    return da.weighted(weights).mean(dim=(\"latitude\", \"longitude\"), skipna=True)\n\n\nNINO_REGIONS = {\n    \"nino12\": {\"latitude\": (0, -10), \"longitude\": (270, 280)},\n    \"nino3\": {\"latitude\": (5, -5), \"longitude\": (210, 270)},\n    \"nino34\": {\"latitude\": (5, -5), \"longitude\": (190, 240)},\n    \"nino4\": {\"latitude\": (5, -5), \"longitude\": (160, 210)},\n}","key":"PHGNjZK0dT"},{"type":"outputs","id":"1m30wdYNf6j1IQ_alh2la","children":[],"key":"qAkzGeP91d"}],"key":"SbPUjSNJYi"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Computing the Niño indices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kG6w6F3agU"}],"identifier":"computing-the-ni-o-indices","label":"Computing the Niño indices","html_id":"computing-the-ni-o-indices","implicit":true,"key":"x5EtDlEilZ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For each region we area-average SST, remove the monthly climatology to get\nanomalies, then apply a 3-month running mean — the recipe behind NOAA’s Oceanic\nNiño Index (ONI).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Uqm0wu8z65"}],"key":"t9NkCbvoXA"}],"key":"L8A1CPtist"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def nino_index(sst, box):\n    sub = sst.sel(\n        latitude=slice(*box[\"latitude\"]),\n        longitude=slice(*box[\"longitude\"]),\n    )\n    return area_mean(sub)\n\n\nraw = xr.Dataset({name: nino_index(sst, box) for name, box in NINO_REGIONS.items()})\n\nclim = raw.groupby(\"time.month\").mean(\"time\")\nanom = raw.groupby(\"time.month\") - clim\nindices = anom.rolling(time=3, center=True).mean()","key":"MfRB51Km3U"},{"type":"outputs","id":"t0ZaAlw2UtOCwW8RKwVI8","children":[],"key":"mjb3SvSsTA"}],"key":"QACkXviaoL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing ENSO","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VTiYhQf2dF"}],"identifier":"visualizing-enso","label":"Visualizing ENSO","html_id":"visualizing-enso","implicit":true,"key":"JkVJpDS1oQ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Shading each anomaly red above +0.5 °C and blue below −0.5 °C — the conventional\nEl Niño / La Niña thresholds — turns the series into recognizable ENSO records. The\neastern regions (1+2, 3) swing more than the central-Pacific Niño 4.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"J6CRoAEers"}],"key":"lsvER7A6Cw"}],"key":"apDaJUkU69"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"t = indices[\"time\"].values\n\nfig, axes = plt.subplots(4, 1, figsize=(12, 10), sharex=True)\nfor ax, name in zip(axes, [\"nino12\", \"nino3\", \"nino34\", \"nino4\"]):\n    y = indices[name].values\n    ax.plot(t, y, color=\"black\", lw=0.7)\n    ax.fill_between(t, 0.5, y, where=(y >= 0.5), color=\"tab:red\", alpha=0.6, interpolate=True)\n    ax.fill_between(t, -0.5, y, where=(y <= -0.5), color=\"tab:blue\", alpha=0.6, interpolate=True)\n    ax.axhline(0.5, color=\"grey\", lw=0.5, ls=\"--\")\n    ax.axhline(-0.5, color=\"grey\", lw=0.5, ls=\"--\")\n    ax.set_ylabel(f\"{name}\\n(°C)\")\n\naxes[-1].set_xlabel(\"Year\")\nfig.suptitle(\"Niño SST anomaly indices from HadISST (3-month running mean)\")\nplt.tight_layout()\nplt.show()","key":"mQPOfoJ8IA"},{"type":"outputs","id":"ym7kzHrV6dc4pIn-y9Rju","children":[],"key":"sGPXFapBl2"}],"key":"QyGtm7uIKM"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Spatial patterns of El Niño and La Niña","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Dx62vj6UoS"}],"identifier":"spatial-patterns-of-el-ni-o-and-la-ni-a","label":"Spatial patterns of El Niño and La Niña","html_id":"spatial-patterns-of-el-ni-o-and-la-ni-a","implicit":true,"key":"GUYEh6zIs9"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"The indices collapse the Pacific into a single number, but the events have a\ndistinctive spatial signature. Computing the full SST anomaly field and mapping a\nstrong El Niño against a strong La Niña shows the warm and cold “tongues” that\nstretch along the equator.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vm5JvAdgc9"}],"key":"ML3rs1wr8i"}],"key":"ECS0O7SlUB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sst_clim = sst.groupby(\"time.month\").mean(\"time\")\nsst_anom = sst.groupby(\"time.month\") - sst_clim\n\nevents = {\n    \"El Niño\": indices[\"nino34\"].idxmax(\"time\"),\n    \"La Niña\": indices[\"nino34\"].idxmin(\"time\"),\n}\n\nproj = ccrs.PlateCarree(central_longitude=180)\nfig, axes = plt.subplots(1, 2, figsize=(14, 4), subplot_kw={\"projection\": proj})\n\nfor ax, (kind, date) in zip(axes, events.items()):\n    field = sst_anom.sel(time=date)\n    p = field.plot(\n        ax=ax,\n        transform=ccrs.PlateCarree(),\n        x=\"longitude\",\n        y=\"latitude\",\n        cmap=\"RdBu_r\",\n        vmin=-3,\n        vmax=3,\n        add_colorbar=False,\n    )\n    ax.coastlines(color=\"black\", linewidth=0.6)\n    ax.set_extent([120, 290, -30, 30], crs=ccrs.PlateCarree())\n    ax.set_title(f\"{kind} — {np.datetime_as_string(date.values, unit='M')}\")\n\nfig.colorbar(p, ax=axes, orientation=\"horizontal\", shrink=0.5, pad=0.08, label=\"SST anomaly (°C)\")\nplt.show()","key":"wAc2io2hPz"},{"type":"outputs","id":"6Y4pxbENDEVuVClfIEvHk","children":[],"key":"C17dLN1klb"}],"key":"mRgfzfjaVI"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lLI7wcgwGs"}],"key":"lnIGKSqAvB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"j6QFr8wCcr"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"FvTaZY0ZO4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"We streamed HadISST sea surface temperature from GDEX over OSDF, masked land, and\ncomputed the four standard Niño SST anomaly indices with a 3-month running mean.\nMapping the SST anomaly for a strong El Niño against a strong La Niña revealed the\nequatorial warm and cold tongues behind the indices.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"g32S6drgRI"}],"key":"nLqnha6fuV"},{"type":"heading","depth":3,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"jpu1B94JBS"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"LgpfwYEJdZ"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Continue to the ","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"ndYHr1ajoF"},{"type":"link","url":"/notebooks/workflows/radar","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Radar Data Workflow","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"qIIP5U0pOW"}],"urlSource":"radar.ipynb","dataUrl":"/notebooks.workflows.radar.json","internal":true,"protocol":"file","key":"ys5ZFR374K"},{"type":"text","value":", which works with another\nGDEX observational dataset.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"dhobDb9Zrr"}],"key":"wy6Wfq9sN0"}],"key":"PSWymJDv6H"},{"type":"block","kind":"notebook-content","children":[{"type":"